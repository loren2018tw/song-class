{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "song-class",
  "version": "26.5.30",
  "identifier": "boats.loren.song-class",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "爽課啦(song-class)",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "nsis"
    ],
    "resources": {
      "../dist/": "dist/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "packaging/linux/song-class.desktop.hbs"
      }
    },
    "windows": {
      "nsis": {
        "installerHooks": "packaging/windows/nsis-hooks.nsh"
      }
    }
  }
}